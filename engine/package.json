    "koa": "^2.13.3",
    "koa-body": "^5.0.0",
    "lodash.isplainobject": "^4.0.6",
    "nanoid": "^3.1.30",
    "p-queue": "^6.6.2",
    "redux": "^4.1.0",
    "rfc6902": "^5.0.0",
    "setimmediate": "^1.0.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
