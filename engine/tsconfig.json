{
  "compilerOptions": {
    "strict": true,
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react",
    "declaration": true,
    "declarationDir": "dist/types",
    "noEmit": false,
    "outDir": "dist/js"
  },
  "include": ["src", "packages"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.test.js"]
}
