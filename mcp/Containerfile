FROM node:26-alpine AS build
WORKDIR /app
COPY mcp/package.json ./
COPY core/ ./node_modules/@mcteamster/white-core/
RUN npm install
COPY mcp/index.ts ./
RUN npx esbuild index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js

FROM node:26-alpine
WORKDIR /app
ENV NODE_ENV=production MCP_HTTP_PORT=8000
COPY --from=build /app/dist/index.js .
EXPOSE 8000
HEALTHCHECK --interval=10s --timeout=3s CMD wget -qO- http://localhost:8000/health || exit 1
CMD ["node", "index.js"]
