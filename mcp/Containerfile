FROM node:22-alpine AS build
WORKDIR /build
COPY mcp/package.json .
COPY src/Game.ts src/Cards.ts src/
COPY src/lib/constants.ts src/lib/
COPY mcp/index.ts .
RUN npm install && npx esbuild index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js --banner:js='#!/usr/bin/env node'

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production \
    MCP_HTTP_PORT=8000
COPY --from=build /build/dist/index.js .
EXPOSE 8000
HEALTHCHECK --interval=10s --timeout=3s CMD wget -qO- http://localhost:8000/health || exit 1
CMD ["node", "index.js"]
