{
  "name": "blankwhitecards",
  "private": true,
  "version": "2.3.2",
  "workspaces": [
    "core",
    "app",
    "server",
    "api",
    "mcp"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "lint": "npm run lint -w app",
    "pull:global": "curl https://blankwhite.cards/decks/global.json > ./app/public/decks/global.json && node ./bin/chunk-global.js",
    "serve": "npm run start -w server",
    "serve:mcp": "npm run serve -w mcp",
    "mcp": "tsx ./mcp/index.ts"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "~5.6.2"
  }
}
