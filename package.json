{
  "name": "blankwhitecards",
  "private": true,
  "version": "2.3.3",
  "workspaces": [
    "core",
    "app",
    "server",
    "api",
    "mcp"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app && npm run build -w mcp",
    "lint": "npm run lint -w app",
    "pull:global": "npm run pull:global -w app",
    "serve": "npm run start -w server",
    "serve:local": "npm run dev -w server",
    "serve:mcp": "npm run serve -w mcp",
    "mcp": "tsx ./mcp/index.ts"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "~5.6.2"
  }
}
